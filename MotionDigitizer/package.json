{
  "name": "motion-digitizer",
  "version": "1.1.0",
  "description": "MotionDigitizer - 3D Motion Capture and Analysis Application",
  "main": "electron-main.js",
  "volta": {
    "node": "20.18.0",
    "npm": "10.8.2"
  },
  "scripts": {
    "patch-icon": "node -e \"const p=require('path'),fs=require('fs'),plist=p.join('node_modules/electron/dist/Electron.app/Contents/Info.plist');if(process.platform==='darwin'&&fs.existsSync(plist)){let c=fs.readFileSync(plist,'utf8');c=c.replace(/<key>CFBundleDisplayName<\\/key>\\s*<string>[^<]*<\\/string>/,'<key>CFBundleDisplayName</key>\\n\\t<string>MotionDigitizer</string>');c=c.replace(/<key>CFBundleName<\\/key>\\s*<string>[^<]*<\\/string>/,'<key>CFBundleName</key>\\n\\t<string>MotionDigitizer</string>');c=c.replace('electron.icns','MDigi.icns');fs.writeFileSync(plist,c);const src=p.join('assets','MDigi.icns'),dst=p.join('node_modules/electron/dist/Electron.app/Contents/Resources/MDigi.icns');if(fs.existsSync(src))fs.copyFileSync(src,dst);console.log('Patched Electron.app for MotionDigitizer')}\"",
    "start": "npm run patch-icon && electron .",
    "dev": "npm run patch-icon && electron . --dev",
    "build:native": "cd native && node-gyp configure build",
    "rebuild:native": "cd native && node-gyp rebuild",
    "copy-shared": "node -e \"require('fs-extra').copySync('../shared', 'shared')\"",
    "build": "npm run copy-shared && npm run build:native && electron-builder --win --x64",
    "build:dir": "npm run copy-shared && npm run build:native && electron-builder --win --x64 --dir",
    "build:portable": "npm run copy-shared && npm run build:native && electron-builder --win --x64 -c.win.target=portable",
    "build:mac": "npm run copy-shared && npm run build:native && electron-builder --mac --arm64"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "fs-extra": "^11.3.3",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^11.2.0",
    "nodemon": "^3.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "dat.gui": "^0.7.9",
    "electron-store": "^8.1.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "iconv-lite": "^0.6.3",
    "mathjs": "^11.12.0",
    "plotly.js-dist": "^2.26.0",
    "three": "^0.158.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.motiondigitizer.app",
    "productName": "MotionDigitizer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "index.html",
      "calibration-3d-view.html",
      "src/**/*",
      "shared/**/*",
      "assets/**/*",
      "native/**/*",
      "package.json",
      "node_modules/**/*",
      "MDigi.png",
      "MDigi.ico",
      "assets/MDigi.icns"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/ffmpeg.exe",
      "**/ffprobe.exe",
      "**/ffmpeg",
      "**/ffprobe"
    ],
    "extraResources": [
      {
        "from": "native/build/Release",
        "to": "native",
        "filter": [
          "**/*.node"
        ]
      },
      {
        "from": "MDigi.ico",
        "to": "MDigi.ico"
      },
      {
        "from": "MDigi.png",
        "to": "MDigi.png"
      }
    ],
    "fileAssociations": [
      {
        "ext": "mdp",
        "name": "MotionDigitizer Project",
        "role": "Editor",
        "icon": "./MDigi.icns"
      }
    ],
    "win": {
      "icon": "MDigi.ico",
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "vendor/opencv/bin",
          "to": "opencv",
          "filter": [
            "*.dll"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MotionDigitizer"
    },
    "mac": {
      "icon": "assets/MDigi.icns",
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
