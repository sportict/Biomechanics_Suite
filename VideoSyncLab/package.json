{
    "name": "video-sync-lab",
    "version": "1.0.0",
    "description": "VideoSyncLab - 二画面動画同期編集アプリ",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "cross-env NODE_ENV=development electron .",
        "dev-tools": "cross-env NODE_ENV=development electron . --dev-tools",
        "prebuild": "npm run clean",
        "copy-shared": "node -e \"require('fs').cpSync('../shared', 'shared', {recursive: true})\"",
        "build": "npm run copy-shared && cross-env NODE_ENV=production electron-builder --win --x64",
        "build:dir": "npm run copy-shared && cross-env NODE_ENV=production electron-builder --win --x64 --dir",
        "build:portable": "npm run copy-shared && cross-env NODE_ENV=production electron-builder --win portable --x64",
        "build:mac": "npm run copy-shared && cross-env NODE_ENV=production electron-builder --mac --arm64",
        "postinstall": "electron-builder install-app-deps",
        "clean": "rimraf dist node_modules/.cache"
    },
    "dependencies": {
        "canvas": "^3.2.0",
        "ffmpeg-static": "^5.2.0",
        "ffprobe-static": "^3.1.0",
        "fluent-ffmpeg": "^2.1.3",
        "onnxruntime-node": "^1.23.2",
        "sharp": "^0.34.5",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.2",
        "cross-env": "^7.0.3",
        "electron": "^32.0.0",
        "electron-builder": "^25.1.8",
        "rimraf": "^5.0.5"
    },
    "build": {
        "appId": "com.videosynclab.app",
        "productName": "VideoSyncLab",
        "directories": {
            "output": "dist",
            "buildResources": "build"
        },
        "files": [
            "**/*",

            "!dist",
            "!build",
            "!docs/**",

            "!README.md",
            "!CHANGELOG.md",
            "!*.md",
            "!*.log",

            "!VSL.ico",
            "!VSL.png",
            "!build-portable.js",

            "!.git",
            "!.gitignore",
            "!.editorconfig",
            "!.venv/**",
            "!.cursor/**",

            "!backup_*/**",
            "!UserData/**",
            "!debug_*.png",
            "!test_*.{js,png}",
            "!*.backup_*",
            "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
            "!**/._*",

            "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
            "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
            "!**/node_modules/*.d.ts",
            "!**/node_modules/.bin",
            "!**/node_modules/**/*.{md,txt,yml,yaml}",
            "!node_modules/@electron/get",

            "!**/node_modules/ffmpeg-static/{*.LICENSE,*.README,example.js,install.js}",
            "!**/node_modules/ffmpeg-static/bin/win32/ia32/**",
            "!**/node_modules/ffprobe-static/bin/win32/ia32/**"
        ],
        "asarUnpack": [
            "node_modules/ffmpeg-static/bin/**/*",
            "node_modules/ffprobe-static/bin/**/*"
        ],
        "extraResources": [
            {
                "from": "Models",
                "to": "Models",
                "filter": [
                    "**/*.onnx"
                ]
            },
            {
                "from": "VSL.ico",
                "to": "VSL.ico"
            },
            {
                "from": "VSL.png",
                "to": "VSL.png"
            }
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "build/icon.ico",
            "compression": "maximum",
            "artifactName": "${productName}-Setup-${version}.${ext}",
            "requestedExecutionLevel": "asInvoker"
        },
        "mac": {
            "target": "dmg",
            "icon": "build/icon.icns",
            "category": "public.app-category.education"
        },
        "nsis": {
            "oneClick": false,
            "allowElevation": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "VideoSyncLab"
        },
        "fileAssociations": [
            {
                "ext": "vsl",
                "name": "VideoSyncLab Project",
                "description": "VideoSyncLab Project File",
                "icon": "./VSL.icns",
                "role": "Editor"
            }
        ]
    },
    "keywords": [
        "video",
        "player",
        "electron",
        "synchronization",
        "dual-screen",
        "trimming",
        "editing",
        "frame-accurate",
        "sync-playbook",
        "video-sync-lab"
    ],
    "author": "VideoSyncLab Developer",
    "license": "MIT",
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=8.0.0"
    }
}